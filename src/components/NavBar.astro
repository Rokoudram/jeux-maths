---
import { sections } from "../../config/sections";
const pathname = Astro.url.pathname;
---


<header class="navbar">
    <div class="navbar-inner">
        <a class="logo" href="/jeux-maths">
            <img src="/jeux-maths/inverse_checker.png" alt="Accueil" />
        </a>
        <a href="/jeux-maths">
            Accueil
        </a>

        <nav>
            {
                sections
                    .filter(section => section.nav)
                    .map(section => (
                        <a
                            href={section.href}
                            class:list={{
                                active: pathname.startsWith(section.href),
                                "desktop-only": section.nav_mobile === false
                            }}
                        >
                            {section.title}
                        </a>
                    ))
            }
        </nav>
    </div>
</header>

<style>
    @media (max-width: 700px) {
    .desktop-only {
        display: none;
    }
}

.navbar {
    padding: 0;
    background: white;
    border-radius: 10px;
    width: 100%;
}

.navbar-inner {
    color:black;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 0 auto;
    padding: 0;
}

.logo img{
    margin: 1rem 0 1rem 2rem ;
    max-width: 50px;
    height: auto;
    transition: transform 0.5s ease;
}

.logo img:hover {
    transform: rotate(-5deg) scale(1.1);
}

a {
    font-weight:600 ;
    color: var(--colback);
    transition: transform 0.3s;
}

a:hover {
    transform: scale(1.2);
}

nav {
    flex: 1;
    display: flex;
    justify-content: right;
    gap: 4rem;
    margin: 0 3rem 0 0;
}

nav a {
    position: relative;
    color: black;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.3s, color 0.3s;
}


nav a:hover {
    color: var(--colback);
    transform: scale(1.2);
}

nav a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -0.3rem;
    width: 100%;
    height: 2px;
    background: var(--colback);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.3s ease;
}

nav a:hover::after,
nav a.active::after {
    transform: scaleX(1);
}

@media (max-width: 700px) {
    .navbar-inner {
        flex-direction: column;
        gap: 1rem;
    }

    nav {
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
    }

    .logo {
        display: none;
    }
}

</style>
