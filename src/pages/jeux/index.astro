---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sections } from "../../../config/liste-jeux";
---


<BaseLayout title="Jeux">
    <section class="intro">
        <p>
            Page d'accueil des jeux
        </p>
    </section>

    <div class="grid">
        {
            sections.map(section => (
                <div class="zoom">
                    <a class="card" href={section.href}>
                        <h2>{section.title}</h2>

                        <p>
                            {section.description}
                        </p>

                        <span>
                            Jouer →
                        </span>
                    </a>
                </div>
            ))
        }
    </div>

</BaseLayout>



<style>
.intro {
    min-width: 50px;
    max-width: 800px;
    font-size: 1.2rem;
}

.intro p {
    margin-bottom: 1.5rem;
}

.grid {
    display: grid;
    justify-content: center;
    width: 100%;
    grid-template-columns: repeat(auto-fit,240px);
    gap: 4rem;
}

.card {
    display: flex;
    justify-content: center;
    flex-direction: column;
    align-items: center;
    font-size: 0.85rem;
    color: var(--colback);

    width: 200px;
    height: 120px;
    padding: 20px;

    background-color:white;
    border: 5px solid var(--colback);
    border-radius: 10px;

    text-decoration: none;

    transition:
        transform .65s ease,
        transform var(--transition),
        border-color var(--transition)
}

.card:hover{
    animation: shake .65s cubic-bezier(.36,.07,.19,.97);
    border-color: black;
}

.card h2 {
    margin: 0 0 0 0 ;
    font-size: 1.25rem;
    color: #2b003a;
}


.zoom {
    transition: transform .65s ease;
}

.zoom:hover {
    transform: scale(1.1);
}


@keyframes shake {
    10%,90% {
        transform: rotate(-1deg);
    }

    25%,75% {
        transform:  rotate(2deg);
    }

    40%,60% {
        transform: rotate(-3deg);
    }

    50% {
        transform: rotate(3deg);
    }
}

</style>